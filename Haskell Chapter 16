HC16T6 – nth Fibonacci Number

Main.hs
module Main where
fib :: Int -> Integer
fib 0 = 0
fib 1 = 1
fib n = fib (n - 1) + fib (n - 2)
main :: IO ()
main = do
    print (map fib [0..10])

