HC16T1 – Reverse a String

Main.hs
module Main where
reverseString :: String -> String
reverseString = reverse
main :: IO ()
main = do
    let s = "Haskell"
    putStrLn ("Original: " ++ s)
    putStrLn ("Reversed: " ++ reverseString s)

HC16T2 – Palindrome Checker

Main.hs
module Main where
isPalindrome :: String -> Bool
isPalindrome s = s == reverse s
main :: IO ()
main = do
    let s1 = "level"
        s2 = "hello"
    print (s1 ++ " is palindrome? " ++ show (isPalindrome s1))
    print (s2 ++ " is palindrome? " ++ show (isPalindrome s2))

HC16T3 – Factorial

Main.hs
module Main where
factorial :: Integer -> Integer
factorial 0 = 1
factorial n = n * factorial (n - 1)
main :: IO ()
main = do
    print (factorial 5)

