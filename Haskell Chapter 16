HC16T8 – Insertion Sort

Main.hs
module Main where
insert :: Int -> [Int] -> [Int]
insert x [] = [x]
insert x (y:ys)
    | x <= y    = x : y : ys
    | otherwise = y : insert x ys
insertionSort :: [Int] -> [Int]
insertionSort = foldr insert []
main :: IO ()
main = do
    print (insertionSort [5,2,4,1,3])

HC16T9 – Remove Duplicates from List

Main.hs
module Main where
removeDuplicates :: Eq a => [a] -> [a]
removeDuplicates [] = []
removeDuplicates (x:xs) = x : removeDuplicates (filter (/= x) xs)
main :: IO ()
main = do
    print (removeDuplicates [1,2,2,3,4,4,5])

HC16T10 – Character Frequency in String

Main.hs
module Main where
import Data.List (group, sort)
charFrequency :: String -> [(Char, Int)]
charFrequency = map (\xs -> (head xs, length xs)) . group . sort
main :: IO ()
main = do
    print (charFrequency "haskell")
