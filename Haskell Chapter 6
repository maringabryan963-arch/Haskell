HC6T6
Element Exists in List

Main.hs
elementExists :: Eq a => a -> [a] -> Bool
elementExists _ [] = False
elementExists y (x:xs)
  | y == x    = True
  | otherwise = elementExists y xs
main = do
  print (elementExists 3 [1,2,3,4])
  print (elementExists 'a' "hello")

