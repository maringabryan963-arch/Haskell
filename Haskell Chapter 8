HC8T9
Record Type and Transaction Function

Main.hs
type Address = String
type Value = Int
data Transaction = Transaction
  { fromAddr :: Address
  , toAddr :: Address
  , amount :: Value
  , transactionId :: String
  } deriving Show
createTransaction :: Address -> Address -> Value -> String
createTransaction f t v =
  transactionId (Transaction f t v "TX001")
main :: IO ()
main = do
  print (createTransaction "Alice" "Bob" 500)

