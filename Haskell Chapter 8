HC8T7
Data Types and Describing Animals

Main.hs
data Animal = Dog String | Cat String deriving Show
describeAnimal :: Animal -> String
describeAnimal (Dog n) = "Dog named " ++ n
describeAnimal (Cat n) = "Cat named " ++ n
main :: IO ()
main = do
  putStrLn (describeAnimal (Dog "Buddy"))
  putStrLn (describeAnimal (Cat "Kitty"))

