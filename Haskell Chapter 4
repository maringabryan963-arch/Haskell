HC4T7 – Ignore Elements in a List

Main.hs
firstAndThird (x:_:z:_) = (x, z)
firstAndThird _         = error "List does not have enough elements"
main = do
    print (firstAndThird [1,2,3,4])
    print (firstAndThird ["a","b","c","d"])

