HC1T1 – Function Composition

Main.hs
double :: Int -> Int
double x = x * 2
increment :: Int -> Int
increment x = x + 1
doubleThenIncrement :: Int -> Int
doubleThenIncrement = increment.double
main :: IO()
main = do
    print(double 5)
    print(increment 5)

