HC1T8 – Higher-Order Functions

Main.hs
applyTwice :: (Int -> Int) -> Int -> Int
applyTwice f x = f (f x)
main = do
    print (applyTwice (+1) 5)
    print (applyTwice (*2) 3)
Output:
7
12
