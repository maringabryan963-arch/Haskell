HC5T3

Main.hs
startsWithUppercase :: String -> Bool
startsWithUppercase "" = False
startsWithUppercase (x:_) = x >= 'A' && x <= 'Z'
containsUppercaseWord :: [String] -> Bool
containsUppercaseWord = any startsWithUppercase
main = do
  print (containsUppercaseWord ["hello", "World", "test"])
  print (containsUppercaseWord ["hello", "world"])

