HC2T4 – Converting Between Infix and Prefix Notations

Main.hs
main = do
    print ((+) 5 3)
    print ((*) 10 4)
    print ((&&) True False)
    print (7 + 2)
    print (6 * 5)
    print (True && False)

HC2T5 – Defining and Using Functions

circleArea :: Float -> Float
circleArea r = pi * r * r
isAdult :: Int -> Bool
isAdult age = age >= 18
main = do
    print (circleArea 5.0)
    print (isAdult 20)
    print (isAdult 15)

