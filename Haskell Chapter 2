HC2T1 – Checking Types in GHCi

Main.hs
main = do
    print (42 :: Int)
    print (3.14 :: Double)
    print ("Haskell" :: String)
    print ('Z' :: Char)
    print (True && False)

HC2T2 – Function Type Signatures

Main.hs
add :: Int -> Int -> Int
add x y = x + y
isEven :: Int -> Bool
isEven x = x `mod` 2 == 0
concatStrings :: String -> String -> String
concatStrings a b = a ++ b
main = do
    print (add 3 4)
    print (isEven 7)
    print (concatStrings "Hi " "there")

HC2T3 – Immutable Variables

