HC15T3 – Exception Handler for Traffic Light

Main.hs
module Main where
import Control.Exception
data TrafficLightError = InvalidLight String deriving Show
instance Exception TrafficLightError
main :: IO ()
main = catch action handler
  where
    action = throwIO (InvalidLight "Purple light detected!")
    handler (InvalidLight msg) = putStrLn ("Caught: " ++ msg)

