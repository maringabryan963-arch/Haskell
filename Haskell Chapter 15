HC15T5 – Safe Input Parsing with readMaybe
Use readMaybe to parse user input safely and avoid runtime errors during input parsing.
Main.hs
module Main where
import Text.Read (readMaybe)
main :: IO ()
main = do
    let inputs = ["42", "hello"]
    mapM_ (\s -> case readMaybe s :: Maybe Int of
                    Just n -> putStrLn ("Parsed: " ++ show n)
                    Nothing -> putStrLn ("Invalid: " ++ s)) inputs

HC15T6 – Velocity Calculation with Optionals and Parsing Handling

Main.hs
module Main where
import Text.Read (readMaybe)
calculateVelocity :: Double -> Double -> Maybe Double
calculateVelocity _ 0 = Nothing
calculateVelocity d t = Just (d / t)
main :: IO ()
main = do
    let inputs = [("100","10"),("50","0"),("abc","5")]
    mapM_ (\(dStr,tStr) ->
        case (readMaybe dStr, readMaybe tStr) of
            (Just d, Just t) -> case calculateVelocity d t of
                Just v -> putStrLn ("Velocity = " ++ show v)
                Nothing -> putStrLn "Time cannot be zero!"
            _ -> putStrLn "Invalid input!"
        ) inputs

