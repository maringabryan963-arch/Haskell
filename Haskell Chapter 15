calculateVelocity :: Double -> Double -> Either String Double
calculateVelocity _ 0 = Left "Time cannot be zero!"
calculateVelocity d t = Right (d / t)
main :: IO ()
main = do
    let inputs = [("100","10"),("50","0"),("abc","5")]
    mapM_ (\(dStr,tStr) ->
        case (readMaybe dStr, readMaybe tStr) of
