HC15T8 – Try Function for File IO Exceptions

Main.hs
module Main where
import Control.Exception
import System.IO
main :: IO ()
main = do
    result <- try (readFile "nofile.txt") :: IO (Either SomeException String)
    case result of
        Right content -> putStrLn content
        Left err -> putStrLn ("Caught IO error: " ++ show err)

