HC7T1
Implement an Eq Instance for a Custom Data Type

Main.hs
module Main where
data Color = Red | Green | Blue
instance Eq Color where
  Red   == Red   = True
  Green == Green = True
  Blue  == Blue  = True
  _     == _     = False
main :: IO ()
main = do
  print (Red == Red)
  print (Red == Blue)
  print (Green == Green)

HC7T2
Implement an Ord Instance for a Custom Data Type

Main.hs
data Color = Red | Green | Blue deriving (Show, Eq)
instance Ord Color where
  Red    <= _       = True
  Green  <= Green   = True
  Green  <= Blue    = True
  Blue   <= Blue    = True
  _      <= _       = False
main = do
  print (Red < Green)
  print (Green < Blue)
  print (Blue > Red)
  print (Red >= Red)

Function Using Multiple Constraints

Main.hs
compareValues :: (Eq a, Ord a) => a -> a -> a
compareValues x y
  | x >= y    = x
  | otherwise = y
main = do
  print (compareValues 5 10)
  print (compareValues "apple" "banana")

