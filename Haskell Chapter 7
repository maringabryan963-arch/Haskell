HC7T8
Parse a Value from a String Using Read

Main.hs
data Shape = Circle Double | Rectangle Double Double
  deriving (Show, Read)
parseShape :: String -> Maybe Shape
parseShape str =
  case reads str of
    [(s, "")] -> Just s
    _         -> Nothing
main = do
  print (parseShape "Circle 5")
  print (parseShape "Rectangle 4 6")
  print (parseShape "Triangle 3 4 5")

