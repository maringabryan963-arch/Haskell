HC7T9
Type Class with Multiple Instances

Main.hs
data Shape = Circle Double | Rectangle Double Double
  deriving Show
class Describable a where
  describe :: a -> String
instance Describable Bool where
  describe True  = "This is True"
  describe False = "This is False"
instance Describable Shape where
  describe (Circle r)      = "Circle with radius " ++ show r
  describe (Rectangle w h) = "Rectangle with width " ++ show w ++ " x " ++ show h
main = do
  putStrLn (describe True)
  putStrLn (describe False)
  putStrLn (describe (Circle 4))
  putStrLn (describe (Rectangle 3 5))

HC7T10
Function with Multiple Type Class Constraints

Main.hs
data Shape = Circle Double | Rectangle Double Double
  deriving (Show, Eq, Ord)
class Describable a where
  describe :: a -> String
instance Describable Shape where
  describe (Circle r)      = "Circle with radius " ++ show r
  describe (Rectangle w h) = "Rectangle " ++ show w ++ " x " ++ show h
describeAndCompare :: (Describable a, Ord a) => a -> a -> String
describeAndCompare x y
  | x >= y    = describe x
  | otherwise = describe y
main = do
  putStrLn (describeAndCompare (Circle 5) (Circle 3))
  putStrLn (describeAndCompare (Rectangle 2 3) (Rectangle 4 1))
