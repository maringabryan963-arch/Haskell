HC18T5
Functor Instance for Either

Main.hs
module Main where
data MyEither e a = MyLeft e | MyRight a deriving (Show)
instance Functor (MyEither e) where
    fmap _ (MyLeft x) = MyLeft x
    fmap f (MyRight y) = MyRight (f y)
main :: IO ()
main = do
    let r = MyRight 10 :: MyEither String Int
        l = MyLeft "Error" :: MyEither String Int
    print $ fmap (*2) r
    print $ fmap (*2) l

