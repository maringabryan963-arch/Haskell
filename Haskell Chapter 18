module Main where
compositionLawCheck :: (Functor f, Eq (f c)) => (b -> c) -> (a -> b) -> f a -> Bool
compositionLawCheck f g x = fmap (f . g) x == (fmap f . fmap g) x
main :: IO ()
main = do
    let list = [1,2,3]
        f = (*2)
        g = (+1)
    print $ compositionLawCheck f g list

