sumNonEmpty xs = sum xs

HC13T6 – File Names to Map

Main.hs
import qualified Data.Map as Map
filesToMap :: [String] -> Map.Map Int String
filesToMap files = Map.fromList (zip [1..] files)
main :: IO ()
main =
    print (filesToMap ["Main.hs", "Test.txt", "App.hs"])

HC13T7 – Using Custom Module in Main

Main.hs
sumNonEmpty :: [Int] -> Int
