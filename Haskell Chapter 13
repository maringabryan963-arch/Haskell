HC13T1 – List Files in Directory

Main.hs
import System.Directory (listDirectory)
main :: IO ()
main = do
    files <- listDirectory "."
    print files

HC13T2 – Filter Files by Substring

Main.hs
import Data.List (sort, isInfixOf)
filterAndSort :: String -> [String] -> [String]
filterAndSort sub files = sort (filter (isInfixOf sub) files)
main :: IO ()
main =
    print (filterAndSort "hs" ["Z.hs", "A.txt", "B.hs"])

