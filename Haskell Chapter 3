HC3T1 – Checking if a number is positive, negative, or zero

Main.hs
checkNumber x =
  if x > 0 then "Positive"
  else if x < 0 then "Negative"
  else "Zero"
main = do
    print (checkNumber 5)
    print (checkNumber (-3))
    print (checkNumber 0)

HC3T2 – Determining the grade based on a score using guards

Main.hs
grade x
  | x >= 90   = "A"
  | x >= 80   = "B"
  | x >= 70   = "C"
  | x >= 60   = "D"
  | otherwise = "F"
main = do
    print (grade 95)
    print (grade 72)
    print (grade 50)

HC3T3 – Converting an RGB color to a hex string using let bindings

Main.hs
import Numeric (showHex)
import Data.Char (toUpper)
padHex n = if length h == 1 then '0':h else h
  where h = map toUpper (showHex n "")
rgbToHex (r, g, b) = "#" ++ padHex r ++ padHex g ++ padHex b
main = do
    putStrLn (rgbToHex (255, 0, 127))
    putStrLn (rgbToHex (0, 255, 64))

HC3T4 – Calculating the area of a triangle using Heron's formula

Main.hs
triangleArea a b c =
  let s = (a + b + c) / 2
  in sqrt (s * (s - a) * (s - b) * (s - c))
main = do
    print (triangleArea 3 4 5)
    print (triangleArea 7 8 9)

HC3T5 – Determining the type of a triangle using guards

Main.hs
triangleType a b c
  | a == b && b == c = "Equilateral"
  | a == b || b == c || a == c = "Isosceles"
  | otherwise = "Scalene"
main = do
    print (triangleType 3 3 3)
    print (triangleType 5 5 8)
    print (triangleType 6 7 8)

HC3T6 : Checking leap year using if-then-else

Main.hs
isLeapYear year =
  if year `mod` 400 == 0 then True
  else if year `mod` 100 == 0 then False
  else if year `mod` 4 == 0 then True
  else False
main = do
    print (isLeapYear 2000)
    print (isLeapYear 1900)
    print (isLeapYear 2024)

HC3T7 : Determining the season based on the month using guards

Main.hs
season month
  | month == 12 || month == 1  || month == 2  = "Winter"
  | month == 3  || month == 4  || month == 5  = "Spring"
  | month == 6  || month == 7  || month == 8  = "Summer"
  | month == 9  || month == 10 || month == 11 = "Autumn"
  | otherwise = "Invalid month"
main = do
    print (season 3)
    print (season 7)
    print (season 11)

HC3T8 : Calculating BMI and return category using where

Main.hs
bmiCategory weight height
  | bmi < 18.5  = "Underweight"
  | bmi < 25    = "Normal"
  | bmi < 30    = "Overweight"
  | otherwise   = "Obese"
  where bmi = weight / (height ^ 2)
main = do
    print (bmiCategory 70 1.75)
    print (bmiCategory 90 1.8)

HC3T9 – Advanced Task 9: Finding the maximum of three numbers using let

Main.hs
maxOfThree x y z =
  let maxXY = if x > y then x else y
  in if maxXY > z then maxXY else z
main = do
    print (maxOfThree 10 20 15)
    print (maxOfThree 5 25 10)

HC3T10 : Checking if a string is a palindrome using recursion and guards

isPalindrome :: String -> Bool
isPalindrome s
  | length s <= 1        = True
  | head s == last s     = isPalindrome (tail (init s))
  | otherwise            = False
main = do
    print (isPalindrome "racecar")
    print (isPalindrome "haskell")
    print (isPalindrome "madam")
