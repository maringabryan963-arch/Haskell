HC11T9
Data Type Length with Units

Main.hs
data Length = M Double | Km Double deriving (Show)
instance Eq Length where
    (M a)  == (M b)  = a == b
    (Km a) == (Km b) = a == b
    (M a)  == (Km b) = a == b * 1000
    (Km a) == (M b)  = a * 1000 == b
main = do
    print (M 1000 == Km 1)
    print (M 500 == Km 1)

