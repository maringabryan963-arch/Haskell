HC11T3
Container Type Class for Box

Main.hs
data Box = Box String deriving (Show, Eq)
class Container c where
    isEmpty  :: c -> Bool
    contains :: c -> String -> Bool
    replace  :: c -> String -> c
instance Container Box where
    isEmpty (Box "") = True
    isEmpty _        = False
    contains (Box s) x = s == x
    replace _ new = Box new
main :: IO ()
main = do
    let myBox = Box "Toy"
    print (isEmpty myBox)
    print (contains myBox "Toy")
    print (replace myBox "NewToy")

