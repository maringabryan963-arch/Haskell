WeAccept Instance for Box

Main.hs
data Box = Box String deriving (Show, Eq)
class WeAccept a where
    accepted :: a -> Bool
    fancyFunction :: a -> String
instance WeAccept Box where
    accepted (Box "") = False
    accepted (Box _)  = True
    fancyFunction (Box "") = "Empty Box"
    fancyFunction (Box s)  = "Box contains: " ++ s
acceptedBoxes :: [Box] -> [Box]
acceptedBoxes = filter accepted
main :: IO ()
main = print (acceptedBoxes [Box "Phone", Box "", Box "Book"])

