    return (10, map (\s -> if "secret" `isInfixOf` s then "[REDACTED]" else s))
main :: IO ()
main = do
    let Writer ((res, logged), _) = demo
    putStrLn $ "Value: " ++ show res
    putStrLn "Logged messages:"
    mapM_ putStrLn logged
