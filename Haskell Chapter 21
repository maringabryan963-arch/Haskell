put :: s -> State s ()
put s = State (\_ -> ((),s))
modify :: (s -> s) -> State s ()
modify f = State (\s -> ((), f s))
type Pos = (Int, Int)
type Seed = Int
randomStep :: State (Seed, Pos) ()
randomStep = do
    (seed,(x,y)) <- get
    let dir = seed `mod` 4
        newPos = case dir of
            0 -> (x+1,y)
            1 -> (x-1,y)
            2 -> (x,y+1)
            _ -> (x,y-1)
        newSeed = (seed * 1103515245 + 12345) `mod` (2^31)
    put (newSeed,newPos)
randomWalk :: Int -> State (Seed, Pos) [Pos]
randomWalk 0 = do (_,p) <- get; return [p]
randomWalk n = do
    (_,p) <- get
    randomStep
    rest <- randomWalk (n-1)
    return (p:rest)
