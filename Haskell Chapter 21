    let s' = s + 1
    in (s' >= threshold cfg, s')
runTicks :: Config -> Int -> [(Bool,Int)]
runTicks cfg n = go n 0 []
  where
    go 0 _ acc = reverse acc
    go k st acc =
        let (b,st') = runState (runReader tick cfg) st
        in go (k-1) st' ((b,st'):acc)
