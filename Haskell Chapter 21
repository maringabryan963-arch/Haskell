module Main where
import Data.Monoid
newtype Writer w a = Writer { runWriter :: (a,w) }
instance Monoid w => Functor (Writer w) where
    fmap f (Writer (a,w)) = Writer (f a,w)
instance Monoid w => Applicative (Writer w) where
    pure a = Writer (a,mempty)
    Writer (f,w1) <*> Writer (a,w2) = Writer (f a, w1<>w2)
instance Monoid w => Monad (Writer w) where
    Writer (a,w1) >>= k = let Writer (b,w2) = k a in Writer (b,w1<>w2)
tell :: Monoid w => w -> Writer w ()
tell w = Writer ((),w)
assocLaw :: Bool
assocLaw =
    let m = tell ["a"]
        k _ = tell ["b"]
        h _ = tell ["c"]
        left = (m >>= k) >>= h
        right = m >>= (\x -> k x >>= h)
    in runWriter left == runWriter right
newtype Reader r a = Reader { runReader :: r -> a }
instance Functor (Reader r) where fmap f (Reader ra) = Reader (f . ra)
instance Applicative (Reader r) where
    pure a = Reader (\_ -> a)
    Reader rf <*> Reader ra = Reader (\r -> rf r (ra r))
instance Monad (Reader r) where
    Reader ra >>= k = Reader (\r -> runReader (k (ra r)) r)
ask :: Reader r r
ask = Reader id
local :: (r -> r) -> Reader r a -> Reader r a
local f (Reader ra) = Reader (ra . f)
readerLaw1 :: Eq r => r -> Bool
readerLaw1 r = runReader (local id ask) r == runReader ask r
readerLaw2 :: Eq a => r -> (r -> r) -> (r -> Reader r a) -> Bool
readerLaw2 r f k =
    runReader (local f (ask >>= k)) r
    == runReader (ask >>= (\r' -> local f (k r'))) r
main :: IO ()
main = do
    putStrLn $ "Writer associativity law holds: " ++ show assocLaw
    print $ readerLaw1 5
    print $ readerLaw2 10 (+1) (\x -> Reader (\_ -> x))


