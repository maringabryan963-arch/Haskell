HC20T13 – fibonacciMemo with State Monad

Main.hs
module Main where
import Control.Monad.State
import qualified Data.Map as Map
type Memo = Map.Map Int Int
fibonacciMemo :: Int -> State Memo Int
fibonacciMemo 0 = return 0
fibonacciMemo 1 = return 1
fibonacciMemo n = do
    m <- get
    case Map.lookup n m of
        Just v -> return v
        Nothing -> do
            a <- fibonacciMemo (n-1)
            b <- fibonacciMemo (n-2)
            let v = a + b
            modify (Map.insert n v)
            return v
main :: IO ()
main = print $ evalState (fibonacciMemo 10) Map.empty

HC20T14 – mapMFilter Monadic Map-Filter

Main.hs
module Main where
mapMFilter :: Monad m => (a -> m Bool) -> [a] -> m [a]
mapMFilter _ [] = return []
mapMFilter f (x:xs) = do
    b <- f x
    rest <- mapMFilter f xs
    return (if b then x:rest else rest)
main :: IO ()
main = do
    result <- mapMFilter (\x -> return (x > 2)) [1..5]
    print result

