HC20T4 – countChars with State Monad

Main.hs
module Main where
import Control.Monad.State
countChars :: Char -> String -> State Int ()
countChars c [] = return ()
countChars c (x:xs) = do
    when (x == c) $ modify (+1)
    countChars c xs
main :: IO ()
main = do
    let ((), count) = runState (countChars 'a' "banana") 0
    print count

