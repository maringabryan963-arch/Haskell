HC9T3
Function to Add Values in a Box

Main.hs
data Box a = Empty | Has a deriving Show
addN :: Num a => a -> Box a -> Box a
addN n Empty = Empty
addN n (Has x) = Has (x + n)
main :: IO ()
main = do
  let b = Has 10
  print (addN 5 b)
  print (addN 5 Empty)

HC9T4
Extracting a Value from a Box

Main.hs
data Box a = Empty | Has a deriving Show
extract :: a -> Box a -> a
extract def Empty = def
extract _ (Has x) = x
main :: IO ()
main = do
  let b1 = Has 100
  let b2 = Empty :: Box Int
  print (extract 0 b1)
  print (extract 0 b2)

