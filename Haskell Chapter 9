HC9T7
Engagement Function for Tweets

Main.hs
data Tweet = Tweet { content :: String, likes :: Int, comments :: [Tweet] } deriving Show
engagement :: Tweet -> Int
engagement (Tweet _ l cs) = l + sum (map engagement cs)
main :: IO ()
main = do
  let t1 = Tweet "Hello" 5 []
  let t2 = Tweet "World" 3 [t1]
  print (engagement t1)
  print (engagement t2)

