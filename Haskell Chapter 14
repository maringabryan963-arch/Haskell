HC14T5 – Custom Data Type and Pattern Matching with @

Main.hs
module Main where
data Result a
    = Success a
    | Failure String
    deriving Show
describe :: Result Int -> String
describe r@(Success x) =
    "Success: " ++ show x ++ " | " ++ show r
describe f@(Failure _) =
    "Failure: " ++ show f
main :: IO ()
main = do
    putStrLn (describe (Success 10))
    putStrLn (describe (Failure "Error"))

