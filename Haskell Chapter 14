HC14T8 – Character Frequency Function

Main.hs
module Main where
import Data.List (group, sort)
counts :: String -> [(Char, Int)]
counts =
    map (\xs -> (head xs, length xs))
    . group
    . sort
main :: IO ()
main = do
    let result :: [(Char, Int)]
        result = counts "hello world"
    print result

